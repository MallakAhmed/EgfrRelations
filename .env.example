# EgfrRelations — copy this to .env.local for local overrides
# (these are already handled by the Vite dev proxy in development)

# URL of the deployed EgfrRelations Python ML backend (Railway)
# Leave unset in development — the Vite proxy handles /ml/ automatically
VITE_ML_API_URL=https://your-egfr-ml-backend.railway.app

# URL of the deployed Express simulation backend (Railway)
# Leave unset in development — falls back to http://localhost:8787
VITE_SIMULATION_API_URL=https://your-egfr-simulation-backend.railway.app

# URL of the deployed kidney-model-app (Vercel) — used for the Lab Entry iframe
VITE_KIDNEY_APP_URL=https://your-kidney-model-app.vercel.app
